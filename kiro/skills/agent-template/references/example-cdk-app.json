{
  "name": "dev",
  "description": "Agent for __NAME__ - CDK infrastructure project",
  "prompt": "file://../prompts/dev.md",
  "resources": ["file://README.md", "file://.kiro/specs/**/*.md", "file://.kiro/steering/**/*.md"],
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code"
  ],
  "allowedTools": [
    "read",
    "shell",
    "grep",
    "glob",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "code"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        ".kiro/**",
        ".github/**",
        "bin/**",
        "lib/**",
        "src/**",
        "test/**",
        "README.md",
        "CHANGELOG.md",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "cdk.json",
        "jest.config.ts",
        ".editorconfig",
        ".gitignore"
      ]
    },
    "shell": {
      "autoAllowReadonly": true,
      "deniedCommands": [
        ".*git commit.*",
        ".*git push.*",
        ".*git tag .*",
        ".*npm publish.*",
        ".*cdk deploy.*"
      ]
    }
  }
}
