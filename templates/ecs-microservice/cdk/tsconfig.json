{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true
  },
  "exclude": ["node_modules", "cdk.out", "dist"]
}
